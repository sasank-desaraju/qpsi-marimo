<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>QPSI Biostatistics — Interactive Notebooks</title>
  <script src="https://cdn.tailwindcss.com"></script>
</head>
<body class="font-sans text-gray-800 bg-white p-5">
  <div class="max-w-4xl mx-auto">
    <header class="bg-blue-50 p-6 text-center rounded-lg mb-6">
      <h1 class="text-2xl font-bold mb-2">QPSI Biostatistics</h1>
      <p class="text-sm text-gray-600">Interactive notebooks for graduate medical education at the University of Florida</p>
      <p class="text-xs text-gray-500 mt-1">Quality and Patient Safety Initiative</p>
    </header>

    <main>
      {% if apps %}
      <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
        {% for app in apps %}
        <div class="bg-gray-50 border border-gray-200 rounded-lg overflow-hidden hover:shadow-md transition-shadow">
          <div class="bg-blue-100 p-3 font-semibold text-gray-800">{{ app.display_name }}</div>
          <div class="p-4">
            <a href="{{ app.html_path }}" class="inline-block bg-blue-600 hover:bg-blue-700 text-white py-2 px-4 rounded transition-colors">
              Open Notebook
            </a>
          </div>
        </div>
        {% endfor %}
      </div>
      {% else %}
      <p class="text-center text-gray-500">No notebooks available yet.</p>
      {% endif %}
    </main>

    <footer class="mt-10 pt-6 border-t border-gray-200 text-center text-sm text-gray-600">
      <p>Built with <a href="https://marimo.io" target="_blank" class="text-blue-500 hover:underline">marimo</a> — Interactive Python notebooks in WebAssembly</p>
      <p class="mt-1">Questions? Contact <a href="mailto:sasank.desaraju@ufl.edu" class="text-blue-500 hover:underline">sasank.desaraju@ufl.edu</a></p>
    </footer>
  </div>
</body>
</html>
